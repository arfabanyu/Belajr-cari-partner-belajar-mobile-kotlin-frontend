<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E9E9E9">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notification"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp"/>

    <!-- Tab -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/borderradiuslogin">

        <TextView
            android:id="@+id/tabNotification"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Notification"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/tab_active"/>

        <TextView
            android:id="@+id/tabRequest"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Request"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Search -->
    <EditText
        android:id="@+id/searchNotif"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="Search..."
        android:layout_margin="16dp"
        android:padding="10dp"
        android:background="@drawable/borderradiuslogin"/>

    <!-- List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/listNotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- ITEM NOTIF -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_account_circle_24"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:text="Arfa Banyuu Santoro"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Nanti dikirim yaa, masih dijalan"
                        android:textSize="12sp"
                        android:textColor="#777"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Tambah item lain tinggal copy -->

        </LinearLayout>

    </ScrollView>

</LinearLayout>